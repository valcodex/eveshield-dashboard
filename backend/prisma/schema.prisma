// EveShield Emergency Response Dashboard — Prisma Schema
// PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  ORG_ADMIN
  ORG_OPERATOR
  POLICE
  MEDICAL
}

enum EmergencyStatus {
  PENDING
  ACKNOWLEDGED
  DISPATCHED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum EmergencyPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyType {
  POLICE
  MEDICAL
  FIRE
  GENERAL
}

enum ResponderType {
  POLICE
  MEDICAL
  FIRE
}

enum ResponderStatus {
  AVAILABLE
  ASSIGNED
  EN_ROUTE
  ON_SCENE
  OFF_DUTY
}

enum NotificationType {
  NEW_ALERT
  RESPONDER_ASSIGNED
  LOCATION_UPDATED
  EMERGENCY_RESOLVED
  EMERGENCY_ESCALATED
  BACKUP_REQUESTED
}

// ---------------------------------------------------------------------------
// USERS & AUTH
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  fullName      String
  email         String   @unique
  passwordHash  String
  role          Role
  organization  String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // A user may also be a field responder profile
  responder     Responder?

  assignedEmergencies Emergency[]      @relation("AssignedOperator")
  emergencyUpdates    EmergencyUpdate[]
  notifications       Notification[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// VICTIMS
// ---------------------------------------------------------------------------

model Victim {
  id            String   @id @default(uuid())
  victimCode    String   @unique // human-readable ID shown on dashboard, e.g. VCT-2026-0001
  fullName      String
  phoneNumber   String
  gender        String?
  age           Int?
  bloodGroup    String?
  medicalNotes  String?
  profilePhotoUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  emergencyContacts EmergencyContact[]
  emergencies       Emergency[]
  locations         Location[]

  @@index([phoneNumber])
  @@index([victimCode])
  @@map("victims")
}

model EmergencyContact {
  id       String  @id @default(uuid())
  victimId String
  victim   Victim  @relation(fields: [victimId], references: [id], onDelete: Cascade)
  name     String
  phone    String
  relation String?

  @@index([victimId])
  @@map("emergency_contacts")
}

// ---------------------------------------------------------------------------
// EMERGENCIES
// ---------------------------------------------------------------------------

model Emergency {
  id              String            @id @default(uuid())
  emergencyCode   String            @unique // e.g. EMG-2026-000123
  victimId        String
  victim          Victim            @relation(fields: [victimId], references: [id])
  type            EmergencyType     @default(GENERAL)
  status          EmergencyStatus   @default(PENDING)
  priority        EmergencyPriority @default(HIGH)
  triggeredAt     DateTime          @default(now())
  resolvedAt      DateTime?
  region          String?
  notes           String?

  assignedOperatorId String?
  assignedOperator   User?   @relation("AssignedOperator", fields: [assignedOperatorId], references: [id])

  responders     ResponderAssignment[]
  updates        EmergencyUpdate[]
  locations      Location[]
  notifications  Notification[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([victimId])
  @@map("emergencies")
}

// Timeline of everything that happens on an emergency
model EmergencyUpdate {
  id          String   @id @default(uuid())
  emergencyId String
  emergency   Emergency @relation(fields: [emergencyId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?     @relation(fields: [actorId], references: [id])
  eventType   String    // e.g. "PANIC_TRIGGERED", "GPS_RECEIVED", "OPERATOR_NOTIFIED", "POLICE_DISPATCHED", "NOTE_ADDED", "STATUS_CHANGED", "RESOLVED"
  message     String
  createdAt   DateTime  @default(now())

  @@index([emergencyId])
  @@map("emergency_updates")
}

// ---------------------------------------------------------------------------
// RESPONDERS
// ---------------------------------------------------------------------------

model Responder {
  id           String          @id @default(uuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ResponderType
  badgeNumber  String?
  unit         String?
  status       ResponderStatus @default(AVAILABLE)
  currentLat   Float?
  currentLng   Float?

  assignments  ResponderAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("responders")
}

model ResponderAssignment {
  id          String    @id @default(uuid())
  emergencyId String
  emergency   Emergency @relation(fields: [emergencyId], references: [id], onDelete: Cascade)
  responderId String
  responder   Responder @relation(fields: [responderId], references: [id])
  assignedAt  DateTime  @default(now())
  arrivedAt   DateTime?
  role        String?   // e.g. "primary", "backup"

  @@index([emergencyId])
  @@index([responderId])
  @@map("responder_assignments")
}

// ---------------------------------------------------------------------------
// LOCATION
// ---------------------------------------------------------------------------

model Location {
  id          String    @id @default(uuid())
  victimId    String
  victim      Victim    @relation(fields: [victimId], references: [id], onDelete: Cascade)
  emergencyId String?
  emergency   Emergency? @relation(fields: [emergencyId], references: [id], onDelete: Cascade)
  latitude    Float
  longitude   Float
  accuracy    Float?
  recordedAt  DateTime  @default(now())

  @@index([victimId])
  @@index([emergencyId])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id          String            @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  emergencyId String?
  emergency   Emergency?        @relation(fields: [emergencyId], references: [id], onDelete: Cascade)
  userId      String?           // null = broadcast to all
  user        User?             @relation(fields: [userId], references: [id])
  isRead      Boolean           @default(false)
  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([emergencyId])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------------

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  emergencyId String?
  emergency   Emergency? @relation(fields: [emergencyId], references: [id])
  action      String    // e.g. "LOGIN", "ASSIGN_RESPONDER", "UPDATE_STATUS", "RESOLVE_EMERGENCY"
  details     String?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([emergencyId])
  @@map("audit_logs")
}
